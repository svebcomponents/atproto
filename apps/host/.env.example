# Public origin only; the bridge mounts at /atproto.
SERVICE_URL=https://atproto.svebcomponents.dev

# At least 32 random characters. Keep stable across restarts.
SESSION_SECRET=replace-with-a-long-random-secret

# Newline-separated PKCS#8 PEM OAuth client keys in production.
OAUTH_PRIVATE_KEYS=

# Put this on a persistent volume.
SERVICE_DB_PATH=./.data/service.db

# Hosted embeds need bearer. A same-origin private deployment can use cookie.
SESSION_MODE=bearer

# Optional live-stream tuning.
SPACEDUST_URL=wss://spacedust.microcosm.blue
COMMENT_STREAM_MAX_THREADS=5000
COMMENT_STREAM_MAX_SUBSCRIBERS=10000
COMMENT_STREAM_MAX_SUBSCRIBERS_PER_THREAD=1000
COMMENT_STREAM_HEARTBEAT_MS=15000
