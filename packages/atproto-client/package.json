{
  "name": "@svebcomponents/atproto.client",
  "version": "0.2.0",
  "type": "module",
  "description": "Isomorphic ATProto read utilities and service client for atproto-comments",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/svebcomponents/atproto.git",
    "directory": "packages/atproto-client"
  },
  "homepage": "https://github.com/svebcomponents/atproto#readme",
  "bugs": "https://github.com/svebcomponents/atproto/issues",
  "keywords": [
    "atproto",
    "bluesky",
    "comments"
  ],
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!dist/**/*.test.*"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node -e \"fs.rmSync('dist',{recursive:true,force:true})\" && tsc",
    "check": "tsc --noEmit",
    "lint": "pnpm /^lint:.*/",
    "lint:eslint": "eslint .",
    "lint:format": "prettier --check .",
    "fix": "pnpm /^fix:.*/",
    "fix:eslint": "eslint . --fix",
    "fix:format": "prettier --write .",
    "test": "vitest run",
    "test:dev": "vitest --watch"
  },
  "devDependencies": {
    "@svebcomponents/eslint-config": "workspace:*",
    "@svebcomponents/prettier-config": "workspace:*",
    "@svebcomponents/typescript-config": "workspace:*",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
